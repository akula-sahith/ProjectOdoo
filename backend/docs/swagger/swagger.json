{
  "openapi": "3.0.3",
  "info": {
    "title": "AssetFlow ERP - API Specification",
    "description": "API description for managing assets, departments, users, bookings, transfers, maintenance, and audits.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:5000"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Check API health status",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "message": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/departments": {
      "get": {
        "summary": "Retrieve all departments",
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      },
      "post": {
        "summary": "Create a new department",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "department_name": { "type": "string" },
                  "parent_department_id": { "type": "integer" },
                  "department_head_id": { "type": "integer" }
                },
                "required": ["department_name"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created"
          }
        }
      }
    },
    "/assets": {
      "get": {
        "summary": "Retrieve all assets"
      },
      "post": {
        "summary": "Create a new asset"
      }
    }
  }
}
